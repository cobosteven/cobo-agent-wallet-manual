# caw-eval 环境配置模板
# 复制本文件为 .env，填入真实凭证后使用：
#   cp .env.example .env
# .env 已加入 .gitignore，不会提交到代码库。

# ── Langfuse Project（数据集读写 + session trace + 评分写入）────────────────────
# 同一个 project 用于所有 Langfuse 操作，填入对应的 project 凭证：
LANGFUSE_PUBLIC_KEY=<pk-lf-your-project>
LANGFUSE_SECRET_KEY=<sk-lf-your-project>
LANGFUSE_HOST=https://langfuse.1cobo.com

# ── 可选：LLM-as-Judge 评分 ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=<your-anthropic-key>
