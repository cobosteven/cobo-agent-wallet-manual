# caw-eval 环境配置模板
# 复制本文件为 .env，填入真实凭证后使用：
#   cp .env.example .env
# .env 已加入 .gitignore，不会提交到代码库。

# ── CAW Backend ──────────────────────────────────────────────────────────────
# AGENT_WALLET_API_URL 和 CAW_API_KEY 会自动从 ~/.cobo-agentic-wallet/config
# 读取（与 caw CLI / otel_report.py 保持一致），无需在此配置。
# 若需覆盖，取消下方注释：
# AGENT_WALLET_API_URL=https://api-core.agenticwallet.sandbox.cobo.com
# CAW_API_KEY=<your-caw-api-key>

# ── Langfuse Dataset Project（数据集读写）────────────────────────────────────
# 用于 generate_dataset.py / run_eval.py list
LANGFUSE_DATASET_PUBLIC_KEY=<pk-lf-dataset-project>
LANGFUSE_DATASET_SECRET_KEY=<sk-lf-dataset-project>
LANGFUSE_DATASET_HOST=https://langfuse.1cobo.com

# ── Langfuse Results Project（session trace + 评分写入）──────────────────────
# 用于 run_eval.py upload / score_traces.py
# 根据目标环境（sandbox / prod）填入对应的 project 凭证：
LANGFUSE_RESULT_PUBLIC_KEY=<pk-lf-results-project>
LANGFUSE_RESULT_SECRET_KEY=<sk-lf-results-project>
LANGFUSE_RESULT_HOST=https://langfuse.1cobo.com

# ── 可选：LLM-as-Judge 评分 ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=<your-anthropic-key>
